# HugeGraph-AI-Memory unified configuration
# Copy this file to .env and fill in your credentials.

# ------------------------------------------------------------------
# HugeGraph
# ------------------------------------------------------------------
HUGEGRAPH_URL=http://127.0.0.1:8080
HUGEGRAPH_USER=admin
HUGEGRAPH_PASS=admin
HUGEGRAPH_GRAPH=hugegraph

# ------------------------------------------------------------------
# LLM (OpenAI-compatible, e.g. MiMo v2.5 Pro)
# ------------------------------------------------------------------
LLM_BASE_URL=https://api.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5-pro
LLM_API_KEY=
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# ------------------------------------------------------------------
# Embedding
# ------------------------------------------------------------------
EMBEDDING_TYPE=sentence_transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
# EMBEDDING_API_KEY=
# EMBEDDING_API_BASE=

# ------------------------------------------------------------------
# Vector / Fulltext backends
# ------------------------------------------------------------------
VECTOR_BACKEND=faiss
FULLTEXT_BACKEND=bm25
# FAISS_INDEX_PATH=
BM25_INDEX_NAME=memory_bm25

# ------------------------------------------------------------------
# Rerank (optional)
# ------------------------------------------------------------------
RERANK_ENABLED=false
RERANK_BACKEND=sentence_transformers
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANK_API_KEY=
# RERANK_API_BASE=
RERANK_TOP_K=10
RERANK_BATCH_SIZE=32

# ------------------------------------------------------------------
# Sparse vector hybrid retrieval (optional)
# ------------------------------------------------------------------
SPARSE_ENABLED=false
SPARSE_BACKEND=bm25_tokens
SPARSE_WEIGHT=0.3

# ------------------------------------------------------------------
# Memory behavior
# ------------------------------------------------------------------
EBBINGHAUS_K=0.821
EBBINGHAUS_REINFORCE=0.3
DEFAULT_TOP_K=5

# ------------------------------------------------------------------
# Server / MCP
# ------------------------------------------------------------------
MEMORY_SERVER_HOST=127.0.0.1
MEMORY_SERVER_PORT=8765
MCP_SERVER_NAME=hugegraph-memory
MCP_SERVER_PORT=8848

# ------------------------------------------------------------------
# Paths
# ------------------------------------------------------------------
# MEMORY_DB_PATH=
# MEMORY_DATA_DIR=

# ------------------------------------------------------------------
# Distillation (Experience + Skill)
# ------------------------------------------------------------------
DISTILLATION_ENABLED=false
EXPERIENCE_THRESHOLD=5

# ------------------------------------------------------------------
# Multimodal (optional)
# ------------------------------------------------------------------
MULTIMODAL_ENABLED=false
# VISION_MODEL=
# ASR_MODEL=
