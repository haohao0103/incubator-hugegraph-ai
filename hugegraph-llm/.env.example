# Copy this file to .env and fill in your own API keys / endpoints.
# All sensitive values are intentionally left blank below.

LANGUAGE=EN
CHAT_LLM_TYPE=openai
EXTRACT_LLM_TYPE=openai
TEXT2GQL_LLM_TYPE=openai
AGENT_LLM_TYPE=openai
EMBEDDING_TYPE=openai
RERANKER_TYPE=
KEYWORD_EXTRACT_TYPE=llm
WINDOW_SIZE=3
HYBRID_LLM_WEIGHTS=0.5

# --- OpenAI-compatible LLM (default) ---
# Example: https://api.openai.com/v1
OPENAI_CHAT_API_BASE=https://api.xiaomimimo.com/v1
OPENAI_CHAT_API_KEY=your_api_key_here
OPENAI_CHAT_LANGUAGE_MODEL=mimo-v2.5-pro

OPENAI_EXTRACT_API_BASE=https://api.xiaomimimo.com/v1
OPENAI_EXTRACT_API_KEY=your_api_key_here
OPENAI_EXTRACT_LANGUAGE_MODEL=mimo-v2.5-pro

OPENAI_TEXT2GQL_API_BASE=https://api.xiaomimimo.com/v1
OPENAI_TEXT2GQL_API_KEY=your_api_key_here
OPENAI_TEXT2GQL_LANGUAGE_MODEL=mimo-v2.5-pro

OPENAI_AGENT_API_BASE=https://api.xiaomimimo.com/v1
OPENAI_AGENT_API_KEY=your_api_key_here
OPENAI_AGENT_LANGUAGE_MODEL=mimo-v2.5-pro

OPENAI_EMBEDDING_API_BASE=https://api.xiaomimimo.com/v1
OPENAI_EMBEDDING_API_KEY=your_api_key_here
OPENAI_EMBEDDING_MODEL=mimo-v2.5-pro

OPENAI_CHAT_TOKENS=4096
OPENAI_EXTRACT_TOKENS=256
OPENAI_TEXT2GQL_TOKENS=4096
OPENAI_AGENT_TOKENS=8192

COHERE_BASE_URL=https://api.cohere.com/v1/rerank
RERANKER_API_KEY=
RERANKER_MODEL=

# --- Ollama (optional) ---
OLLAMA_CHAT_HOST=127.0.0.1
OLLAMA_CHAT_PORT=11434
OLLAMA_CHAT_LANGUAGE_MODEL=
OLLAMA_EXTRACT_HOST=127.0.0.1
OLLAMA_EXTRACT_PORT=11434
OLLAMA_EXTRACT_LANGUAGE_MODEL=
OLLAMA_TEXT2GQL_HOST=127.0.0.1
OLLAMA_TEXT2GQL_PORT=11434
OLLAMA_TEXT2GQL_LANGUAGE_MODEL=
OLLAMA_AGENT_HOST=127.0.0.1
OLLAMA_AGENT_PORT=11434
OLLAMA_AGENT_LANGUAGE_MODEL=
OLLAMA_EMBEDDING_HOST=127.0.0.1
OLLAMA_EMBEDDING_PORT=11434
OLLAMA_EMBEDDING_MODEL=

# --- LiteLLM (optional) ---
LITELLM_CHAT_API_KEY=
LITELLM_CHAT_API_BASE=
LITELLM_CHAT_LANGUAGE_MODEL=openai/gpt-4.1-mini
LITELLM_CHAT_TOKENS=8192
LITELLM_EXTRACT_API_KEY=
LITELLM_EXTRACT_API_BASE=
LITELLM_EXTRACT_LANGUAGE_MODEL=openai/gpt-4.1-mini
LITELLM_EXTRACT_TOKENS=256
LITELLM_TEXT2GQL_API_KEY=
LITELLM_TEXT2GQL_API_BASE=
LITELLM_TEXT2GQL_LANGUAGE_MODEL=openai/gpt-4.1-mini
LITELLM_TEXT2GQL_TOKENS=4096
LITELLM_AGENT_API_KEY=
LITELLM_AGENT_API_BASE=
LITELLM_AGENT_LANGUAGE_MODEL=openai/gpt-4.1-mini
LITELLM_AGENT_TOKENS=8192
LITELLM_EMBEDDING_API_KEY=
LITELLM_EMBEDDING_API_BASE=
LITELLM_EMBEDDING_MODEL=openai/text-embedding-3-small

# --- HugeGraph ---
GRAPH_URL=http://127.0.0.1:8080
GRAPH_NAME=hugegraph
GRAPH_USER=admin
GRAPH_PWD=xxx
GRAPH_SPACE=

# --- RAG / GraphRAG tuning ---
LIMIT_PROPERTY=False
MAX_GRAPH_PATH=10
MAX_GRAPH_ITEMS=30
EDGE_LIMIT_PRE_LABEL=8
VECTOR_DIS_THRESHOLD=0.9
TOPK_PER_KEYWORD=1
TOPK_RETURN_RESULTS=20
COMMUNITY_DETECTION_ALGORITHM=leiden
MAX_COMMUNITY_LEVELS=2
MIN_COMMUNITY_SIZE=3
COMMUNITY_RESOLUTION=1.0
MAX_COMMUNITY_REPORTS=100
ENABLE_PROVENANCE=False
ENABLE_LOGIN=False
USER_TOKEN=4321
ADMIN_TOKEN=xxxx

# --- MemSim benchmark ---
MEMSIM_DATA_PATH=
MEMSIM_SAMPLE_PER_SPLIT=20

# --- Vector DB (optional) ---
QDRANT_HOST=
QDRANT_PORT=6333
QDRANT_API_KEY=
MILVUS_HOST=
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
CUR_VECTOR_INDEX=Faiss

ENABLE_HYDE=False
HYDE_MODE=prefix
HYDE_MIN_QUERY_LENGTH=100
ENABLE_GREMLIN_VALIDATION=True
GREMLIN_MAX_RETRIES=3
CHUNK_SIM_K=5
CHUNK_SIM_THRESHOLD=0.7
COMMUNITY_TOP_K=5
ENTITY_TOP_K=10
CHUNK_TOP_K=20
QUALITY_MIN_COMPLETENESS=0.8
QUALITY_MIN_CONNECTIVITY=0.9
QUALITY_MIN_CONSISTENCY=0.85
QUALITY_ENABLE_AUTO_ASSESS=False
KNOWLEDGE_DEFAULT_TTL_DAYS=90
KNOWLEDGE_STALE_THRESHOLD=0.7
KNOWLEDGE_EXPIRY_CHECK_INTERVAL=24
E2E_DEFAULT_QUERY_MODE=auto
E2E_CHUNK_SIZE=512
E2E_CHUNK_OVERLAP=50
CONTEXT_MAX_TURNS=10
CONTEXT_MAX_EVIDENCE=10
CONTEXT_ENABLE_QUERY_REWRITE=True
ENTITY_RESOLUTION_THRESHOLD=0.85
ENTITY_RESOLUTION_BATCH_SIZE=50
ENTITY_RESOLUTION_STRATEGY=hybrid
HYDE_MAX_QUERY_LENGTH=100
DRIFT_MAX_DEPTH=2
DRIFT_COMMUNITIES_TOP_K=5
